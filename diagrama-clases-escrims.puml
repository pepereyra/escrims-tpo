@startuml eScrims - Diagrama de Clases

skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam classHeaderBackgroundColor #DDEEFF
skinparam packageBackgroundColor #F8F8FF
skinparam linetype ortho
hide empty members

title eScrims - Diagrama de clases sin enums

class ApiApplication <<SpringBootApplication>>

package "facade" {
    class ScrimFacade <<Facade>> {
        - controller: ScrimController
        + crearScrim(...): ScrimContext
        + postular(scrimId: UUID, usuario: Usuario, rol: Rol): void
        + confirmar(scrimId: UUID, usuario: Usuario): void
        + iniciar(scrimId: UUID): void
        + finalizar(scrimId: UUID): void
        + cancelar(scrimId: UUID): void
        + configurarNotificacionesEmail(destinatarios: List<Usuario>): void
        + configurarNotificacionesPush(destinatarios: List<Usuario>): void
        + configurarNotificacionesDiscord(destinatarios: List<Usuario>): void
        + procesarScrimsProgramados(): int
        + registrarEstadisticas(scrimId: UUID, resultados: Map<Usuario, int[]>): List<Estadistica>
        + getScrim(scrimId: UUID): ScrimContext
    }
}

package "controller" {
    class ScrimController <<Controller>> {
        - scrimService: ScrimService
        + crearScrim(...): ScrimContext
        + postular(scrimId: UUID, usuario: Usuario, rol: Rol): void
        + confirmar(scrimId: UUID, usuario: Usuario): void
        + iniciar(scrimId: UUID): void
        + finalizar(scrimId: UUID): void
        + cancelar(scrimId: UUID): void
        + configurarNotificacionesEmail(destinatarios: List<Usuario>): NotificationSubscriber
        + configurarNotificacionesPush(destinatarios: List<Usuario>): NotificationSubscriber
        + configurarNotificacionesDiscord(destinatarios: List<Usuario>): NotificationSubscriber
        + procesarScrimsProgramados(ahora: LocalDateTime): int
        + registrarEstadisticas(scrimId: UUID, resultados: Map<Usuario, int[]>): List<Estadistica>
        + getScrim(scrimId: UUID): ScrimContext
    }
}

package "controller.api" {
    class ApiConfig <<Configuration>> {
        + eventBus(): DomainEventBus
        + notificadorFactory(): NotificadorFactory
        + scrimFacade(...): ScrimFacade
    }

    class OpenApiConfig <<Configuration>> {
        + escrimsOpenApi(): OpenAPI
    }

    class UsuarioRestController <<RestController>> {
        - usuarios: UsuarioApiRepository
        + crear(request: CrearUsuarioRequest): UsuarioResponse
        + listar(): List<UsuarioResponse>
    }

    class ScrimRestController <<RestController>> {
        - facade: ScrimFacade
        - usuarios: UsuarioApiRepository
        + crearScrim(request: CrearScrimRequest): ScrimResponse
        + obtenerScrim(scrimId: UUID): ScrimResponse
        + postular(scrimId: UUID, request: PostulacionRequest): ScrimResponse
        + confirmar(scrimId: UUID, request: UsuarioOperacionRequest): ScrimResponse
        + procesarScheduler(request: SchedulerRequest): SchedulerResponse
        + registrarEstadisticas(...): List<EstadisticaResponse>
    }

    class UsuarioApiRepository <<Repository>> {
        - usuariosPorUsername: Map<String, Usuario>
        + guardar(usuario: Usuario): Usuario
        + buscar(username: String): Usuario
        + listar(): Collection<Usuario>
    }

    class ApiDtos <<DTO>>
    class ApiExceptionHandler <<RestControllerAdvice>>
}

package "service" {
    class ScrimService <<Service>> {
        - scrims: Map<UUID, ScrimContext>
        - eventBus: DomainEventBus
        - notificadorFactory: NotificadorFactory
        - schedulerService: ScrimSchedulerService
        + crearScrim(...): ScrimContext
        + postular(scrimId: UUID, usuario: Usuario, rol: Rol): void
        + confirmar(scrimId: UUID, usuario: Usuario): void
        + iniciar(scrimId: UUID): void
        + finalizar(scrimId: UUID): void
        + cancelar(scrimId: UUID): void
        + configurarNotificacionesEmail(destinatarios: List<Usuario>): NotificationSubscriber
        + configurarNotificacionesPush(destinatarios: List<Usuario>): NotificationSubscriber
        + configurarNotificacionesDiscord(destinatarios: List<Usuario>): NotificationSubscriber
        + configurarNotificaciones(destinatarios: List<Usuario>, estrategia: NotificadorStrategy): NotificationSubscriber
        + procesarScrimsProgramados(ahora: LocalDateTime): int
        + registrarEstadisticas(scrimId: UUID, resultados: Map<Usuario, int[]>): List<Estadistica>
        + getScrim(scrimId: UUID): ScrimContext
    }

    class ScrimSchedulerService <<Service>> {
        - scrimService: ScrimService
        + procesarScrimsProgramados(): int
        + procesarScrimsProgramados(ahora: LocalDateTime): int
    }
}

package "domain.model" {
    class Usuario {
        - id: UUID
        - username: String
        - email: String
        - rangoPorJuego: Map<String, Integer>
        - rolesPreferidos: List<Rol>
        - region: String
        - latenciaPromedio: int
        - strikes: int
        - cooldownHasta: LocalDateTime
        - verificado: boolean
        + verificarEmail(): void
        + isCooldownActivo(): boolean
        + getRangoEnJuego(juego: String): int
    }

    class Rol <<ValueObject>> {
        - nombre: String
        - juego: String
        + getNombre(): String
        + getJuego(): String
    }

    class Equipo
    class Confirmacion
    class Estadistica

    class Postulacion {
        - usuario: Usuario
        - rolDeseado: Rol
        - estado: EstadoPostulacion
        + aceptar(): void
        + rechazar(): void
        + estaAceptada(): boolean
    }

    interface EstadoPostulacion <<interface>> {
        + getNombre(): String
        + estaAceptada(): boolean
    }

    class PendientePostulacion
    class AceptadaPostulacion
    class RechazadaPostulacion

    class Notificacion {
        - tipo: String
        - canal: String
        - payload: String
        - estado: EstadoNotificacion
        + marcarEnviada(): void
        + marcarFallida(): void
    }

    interface EstadoNotificacion <<interface>> {
        + getNombre(): String
    }

    class PendienteNotificacion
    class EnviadaNotificacion
    class FallidaNotificacion
}

package "domain.state" {
    interface ScrimState <<State>> {
        + postular(ctx: ScrimContext, usuario: Usuario, rol: Rol): void
        + confirmar(ctx: ScrimContext, usuario: Usuario): void
        + iniciar(ctx: ScrimContext): void
        + finalizar(ctx: ScrimContext): void
        + cancelar(ctx: ScrimContext): void
        + getNombre(): String
    }

    class ScrimContext <<Context>> {
        - state: ScrimState
        - postulaciones: List<Postulacion>
        - confirmaciones: List<Confirmacion>
        - eventBus: DomainEventBus
        - matchmakingStrategy: MatchmakingStrategy
        + postular(usuario: Usuario, rol: Rol): void
        + confirmar(usuario: Usuario): void
        + iniciar(): void
        + finalizar(): void
        + cancelar(): void
        + cuposDisponibles(): int
        + todosConfirmaron(): boolean
        + publicarEvento(evento: DomainEvent): void
    }

    class ScrimBuilder <<Builder>> {
        - eventBus: DomainEventBus
        - matchmakingStrategy: MatchmakingStrategy
        + matchmakingStrategy(strategy: MatchmakingStrategy): ScrimBuilder
        + build(): ScrimContext
    }

    class BuscandoState
    class LobbyArmadoState
    class ConfirmadoState
    class EnJuegoState
    class FinalizadoState
    class CanceladoState
}

package "domain.matchmaking" {
    interface MatchmakingStrategy <<Strategy>> {
        + esCompatible(usuario: Usuario, scrim: ScrimContext): boolean
    }

    class ByMMRStrategy <<ConcreteStrategy>>
    class ByLatencyStrategy <<ConcreteStrategy>>
    class ByHistoryStrategy <<ConcreteStrategy>>
    class CompositeMatchmakingStrategy <<CompositeStrategy>>
}

package "infra.events" {
    interface DomainEvent <<Event>> {
        + getScrimId(): UUID
        + getTipo(): String
        + getFecha(): LocalDateTime
    }

    class ScrimCreadoEvent
    class ScrimStateChangedEvent

    interface Subscriber <<Observer>> {
        + onEvent(evento: DomainEvent): void
    }

    class DomainEventBus <<Subject>> {
        - subscribers: List<Subscriber>
        + subscribe(s: Subscriber): void
        + unsubscribe(s: Subscriber): void
        + publish(evento: DomainEvent): void
    }

    class NotificationSubscriber <<Observer>> {
        - destinatarios: List<Usuario>
        - notificador: NotificadorStrategy
        + onEvent(evento: DomainEvent): void
    }
}

package "infra.notification" {
    interface NotificadorStrategy <<Strategy>> {
        + getCanal(): String
        + enviar(destinatario: Usuario, notificacion: Notificacion): void
    }

    class EmailNotificador <<ConcreteStrategy>>
    class PushNotificador <<ConcreteStrategy>>
    class DiscordNotificador <<ConcreteStrategy>>
    class SendGridEmailAdapter <<Adapter>>
    class FirebasePushAdapter <<Adapter>>
    class DiscordWebhookAdapter <<Adapter>>

    interface NotificadorFactory <<AbstractFactory>> {
        + crearEmailNotificador(): NotificadorStrategy
        + crearPushNotificador(): NotificadorStrategy
        + crearDiscordNotificador(): NotificadorStrategy
    }

    class DevNotificadorFactory <<ConcreteFactory>>
    class ProdNotificadorFactory <<ConcreteFactory>>
}

ApiApplication ..> UsuarioRestController : expone REST
ApiApplication ..> ScrimRestController : expone REST
ApiConfig ..> ScrimFacade : configura bean
ApiConfig ..> ScrimController : configura bean
ApiConfig ..> ScrimService : configura bean
OpenApiConfig ..> ApiDtos : documenta contratos REST
UsuarioRestController --> UsuarioApiRepository : persiste en memoria
UsuarioRestController ..> ApiDtos : recibe/responde JSON
ScrimRestController --> ScrimFacade : delega casos de uso
ScrimRestController --> UsuarioApiRepository : resuelve usuarios
ScrimRestController ..> ApiDtos : recibe/responde JSON
ApiExceptionHandler ..> ApiDtos : error JSON

ScrimFacade --> ScrimController : delega
ScrimController --> ScrimService : delega
ScrimService --> ScrimBuilder : crea scrims
ScrimService --> NotificadorFactory : crea estrategias
ScrimService --> DomainEventBus : registra subscribers
ScrimService *-- ScrimSchedulerService : coordina scheduler

Usuario --> Rol : prefiere
Postulacion --> Usuario
Postulacion --> Rol
Postulacion --> EstadoPostulacion
EstadoPostulacion <|.. PendientePostulacion
EstadoPostulacion <|.. AceptadaPostulacion
EstadoPostulacion <|.. RechazadaPostulacion
Notificacion --> EstadoNotificacion
EstadoNotificacion <|.. PendienteNotificacion
EstadoNotificacion <|.. EnviadaNotificacion
EstadoNotificacion <|.. FallidaNotificacion

ScrimContext *-- ScrimState : estado actual
ScrimContext o-- Postulacion
ScrimContext o-- Confirmacion
ScrimContext --> DomainEventBus : publica
ScrimContext --> MatchmakingStrategy : delega compatibilidad
ScrimBuilder ..> ScrimContext : <<creates>>
ScrimBuilder --> MatchmakingStrategy : configura

ScrimState <|.. BuscandoState
ScrimState <|.. LobbyArmadoState
ScrimState <|.. ConfirmadoState
ScrimState <|.. EnJuegoState
ScrimState <|.. FinalizadoState
ScrimState <|.. CanceladoState

MatchmakingStrategy <|.. ByMMRStrategy
MatchmakingStrategy <|.. ByLatencyStrategy
MatchmakingStrategy <|.. ByHistoryStrategy
MatchmakingStrategy <|.. CompositeMatchmakingStrategy
CompositeMatchmakingStrategy o-- MatchmakingStrategy

DomainEvent <|.. ScrimCreadoEvent
DomainEvent <|.. ScrimStateChangedEvent
DomainEventBus o-- Subscriber
Subscriber <|.. NotificationSubscriber
NotificationSubscriber --> NotificadorStrategy : delega envio
NotificationSubscriber ..> Notificacion : crea

NotificadorStrategy <|.. EmailNotificador
NotificadorStrategy <|.. PushNotificador
NotificadorStrategy <|.. DiscordNotificador
NotificadorStrategy <|.. SendGridEmailAdapter
NotificadorStrategy <|.. FirebasePushAdapter
NotificadorStrategy <|.. DiscordWebhookAdapter
NotificadorFactory <|.. DevNotificadorFactory
NotificadorFactory <|.. ProdNotificadorFactory
NotificadorFactory ..> NotificadorStrategy : <<creates>>
ProdNotificadorFactory ..> SendGridEmailAdapter : <<creates>>
ProdNotificadorFactory ..> FirebasePushAdapter : <<creates>>
ProdNotificadorFactory ..> DiscordWebhookAdapter : <<creates>>

@enduml
