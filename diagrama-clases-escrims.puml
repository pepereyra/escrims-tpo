@startuml
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam classHeaderBackgroundColor #DDEEFF
skinparam packageBackgroundColor #F8F8FF
hide empty members

title eScrims - Diagrama de clases

class ApiApplication <<SpringBootApplication>>

package facade {
    class ScrimFacade <<Facade>> {
        - controller: ScrimController
        + crearScrim(): ScrimContext
        + postular(): void
        + confirmar(): void
        + iniciar(): void
        + finalizar(): void
        + cancelar(): void
        + cambiarRol(): void
        + intercambiarRoles(): void
        + moverASuplente(): void
        + configurarNotificacionesEmail(): void
        + configurarNotificacionesPush(): void
        + configurarNotificacionesDiscord(): void
        + procesarScrimsProgramados(): int
        + registrarEstadisticas(): List
        + getScrim(): ScrimContext
    }
}

package controller {
    class ScrimController <<Controller>> {
        - scrimService: ScrimService
        + crearScrim(): ScrimContext
        + postular(): void
        + confirmar(): void
        + iniciar(): void
        + finalizar(): void
        + cancelar(): void
        + cambiarRol(): void
        + intercambiarRoles(): void
        + moverASuplente(): void
        + procesarScrimsProgramados(): int
        + registrarEstadisticas(): List
        + getScrim(): ScrimContext
    }
}

package controller_api {
    class ApiConfig <<Configuration>>
    class OpenApiConfig <<Configuration>>
    class UsuarioRestController <<RestController>>
    class ScrimRestController <<RestController>>
    class UsuarioApiRepository <<Repository>>
    class ApiDtos <<DTO>>
    class ApiExceptionHandler <<RestControllerAdvice>>
}

package service {
    interface ScrimRepository <<Repository>> {
        + save(scrim: ScrimContext): ScrimContext
        + findById(scrimId: UUID): Optional
        + findAll(): Collection
    }

    class InMemoryScrimRepository <<Repository>>

    class ScrimService <<Service>> {
        - scrimRepository: ScrimRepository
        - eventBus: DomainEventBus
        - notificadorFactory: NotificadorFactory
        - schedulerService: ScrimSchedulerService
        + crearScrim(): ScrimContext
        + postular(): void
        + confirmar(): void
        + iniciar(): void
        + finalizar(): void
        + cancelar(): void
        + cambiarRol(): void
        + intercambiarRoles(): void
        + moverASuplente(): void
        + registrarEstadisticas(): List
        + getScrim(): ScrimContext
    }

    class ScrimSchedulerService <<Service>>
}

package infra_persistence {
    class UsuarioJpaEntity <<JPAEntity>>
    class ScrimJpaEntity <<JPAEntity>>
    class PostulacionJpaEntity <<JPAEntity>>
    class ConfirmacionJpaEntity <<JPAEntity>>
    class EstadisticaJpaEntity <<JPAEntity>>
    interface SpringDataUsuarioJpaRepository <<Repository>>
    interface SpringDataScrimJpaRepository <<Repository>>
    class JpaScrimRepositoryAdapter <<RepositoryAdapter>>
}

package domain_model {
    class Usuario {
        - id: UUID
        - username: String
        - email: String
        - region: String
        - latenciaPromedio: int
        - verificado: boolean
        + verificarEmail(): void
        + isCooldownActivo(): boolean
        + getRangoEnJuego(): int
    }

    class Rol <<ValueObject>>
    class Equipo
    class Confirmacion
    class Estadistica

    class Postulacion {
        - usuario: Usuario
        - rolDeseado: Rol
        - estado: EstadoPostulacion
        + aceptar(): void
        + rechazar(): void
        + marcarSuplente(): void
        + cambiarRol(): void
        + estaAceptada(): boolean
    }

    interface EstadoPostulacion <<interface>>
    class PendientePostulacion
    class AceptadaPostulacion
    class RechazadaPostulacion
    class SuplentePostulacion

    class Notificacion
    interface EstadoNotificacion <<interface>>
    class PendienteNotificacion
    class EnviadaNotificacion
    class FallidaNotificacion
}

package domain_state {
    interface ScrimState <<State>> {
        + postular(): void
        + confirmar(): void
        + iniciar(): void
        + finalizar(): void
        + cancelar(): void
        + getNombre(): String
    }

    class ScrimContext <<Context>> {
        - state: ScrimState
        - postulaciones: List
        - confirmaciones: List
        - estadisticas: List
        - eventBus: DomainEventBus
        - matchmakingStrategy: MatchmakingStrategy
        + postular(): void
        + confirmar(): void
        + iniciar(): void
        + finalizar(): void
        + cancelar(): void
        + cambiarRol(): void
        + intercambiarRoles(): void
        + moverASuplente(): void
        + cuposDisponibles(): int
        + todosConfirmaron(): boolean
        + publicarEvento(): void
    }

    class ScrimBuilder <<Builder>>
    class BuscandoState
    class LobbyArmadoState
    class ConfirmadoState
    class EnJuegoState
    class FinalizadoState
    class CanceladoState
}

package domain_command {
    interface ScrimCommand <<Command>> {
        + ejecutar(): void
    }

    class CambiarRolCommand <<ConcreteCommand>>
    class IntercambiarRolesCommand <<ConcreteCommand>>
    class MoverASuplenteCommand <<ConcreteCommand>>
}

package domain_matchmaking {
    interface MatchmakingStrategy <<Strategy>>
    class ByMMRStrategy <<ConcreteStrategy>>
    class ByLatencyStrategy <<ConcreteStrategy>>
    class ByHistoryStrategy <<ConcreteStrategy>>
    class CompositeMatchmakingStrategy <<CompositeStrategy>>
}

package infra_events {
    interface DomainEvent <<Event>>
    class ScrimCreadoEvent
    class ScrimStateChangedEvent
    interface Subscriber <<Observer>>
    class DomainEventBus <<Subject>>
    class NotificationSubscriber <<Observer>>
}

package infra_notification {
    interface NotificadorStrategy <<Strategy>>
    class EmailNotificador <<ConcreteStrategy>>
    class PushNotificador <<ConcreteStrategy>>
    class DiscordNotificador <<ConcreteStrategy>>
    class SendGridEmailAdapter <<Adapter>>
    class FirebasePushAdapter <<Adapter>>
    class DiscordWebhookAdapter <<Adapter>>
    interface NotificadorFactory <<AbstractFactory>>
    class DevNotificadorFactory <<ConcreteFactory>>
    class ProdNotificadorFactory <<ConcreteFactory>>
}

ApiApplication ..> UsuarioRestController
ApiApplication ..> ScrimRestController
ApiConfig ..> ScrimFacade
ApiConfig ..> ScrimController
ApiConfig ..> ScrimService
OpenApiConfig ..> ApiDtos
UsuarioRestController --> UsuarioApiRepository
UsuarioRestController ..> ApiDtos
ScrimRestController --> ScrimFacade
ScrimRestController --> UsuarioApiRepository
ScrimRestController ..> ApiDtos
ApiExceptionHandler ..> ApiDtos

ScrimFacade --> ScrimController
ScrimController --> ScrimService
ScrimService --> ScrimBuilder
ScrimService ..> ScrimCommand
ScrimService --> NotificadorFactory
ScrimService --> DomainEventBus
ScrimService --> ScrimRepository
ScrimService *-- ScrimSchedulerService
ScrimRepository <|.. InMemoryScrimRepository
ScrimRepository <|.. JpaScrimRepositoryAdapter

JpaScrimRepositoryAdapter --> SpringDataScrimJpaRepository
JpaScrimRepositoryAdapter --> SpringDataUsuarioJpaRepository
JpaScrimRepositoryAdapter ..> ScrimJpaEntity
JpaScrimRepositoryAdapter ..> PostulacionJpaEntity
JpaScrimRepositoryAdapter ..> ConfirmacionJpaEntity
JpaScrimRepositoryAdapter ..> EstadisticaJpaEntity
UsuarioApiRepository --> SpringDataUsuarioJpaRepository
SpringDataUsuarioJpaRepository ..> UsuarioJpaEntity
SpringDataScrimJpaRepository ..> ScrimJpaEntity

ScrimJpaEntity *-- PostulacionJpaEntity
ScrimJpaEntity *-- ConfirmacionJpaEntity
ScrimJpaEntity *-- EstadisticaJpaEntity
PostulacionJpaEntity --> UsuarioJpaEntity
ConfirmacionJpaEntity --> UsuarioJpaEntity
EstadisticaJpaEntity --> UsuarioJpaEntity

Usuario --> Rol
Postulacion --> Usuario
Postulacion --> Rol
Postulacion --> EstadoPostulacion
EstadoPostulacion <|.. PendientePostulacion
EstadoPostulacion <|.. AceptadaPostulacion
EstadoPostulacion <|.. RechazadaPostulacion
EstadoPostulacion <|.. SuplentePostulacion
Notificacion --> EstadoNotificacion
EstadoNotificacion <|.. PendienteNotificacion
EstadoNotificacion <|.. EnviadaNotificacion
EstadoNotificacion <|.. FallidaNotificacion

ScrimContext *-- ScrimState
ScrimContext o-- Postulacion
ScrimContext o-- Confirmacion
ScrimContext o-- Estadistica
ScrimContext --> DomainEventBus
ScrimContext --> MatchmakingStrategy
ScrimBuilder ..> ScrimContext
ScrimBuilder --> MatchmakingStrategy

ScrimState <|.. BuscandoState
ScrimState <|.. LobbyArmadoState
ScrimState <|.. ConfirmadoState
ScrimState <|.. EnJuegoState
ScrimState <|.. FinalizadoState
ScrimState <|.. CanceladoState

ScrimCommand <|.. CambiarRolCommand
ScrimCommand <|.. IntercambiarRolesCommand
ScrimCommand <|.. MoverASuplenteCommand
CambiarRolCommand --> ScrimContext
CambiarRolCommand --> Usuario
CambiarRolCommand --> Rol
IntercambiarRolesCommand --> ScrimContext
IntercambiarRolesCommand --> Usuario
MoverASuplenteCommand --> ScrimContext
MoverASuplenteCommand --> Usuario

MatchmakingStrategy <|.. ByMMRStrategy
MatchmakingStrategy <|.. ByLatencyStrategy
MatchmakingStrategy <|.. ByHistoryStrategy
MatchmakingStrategy <|.. CompositeMatchmakingStrategy
CompositeMatchmakingStrategy o-- MatchmakingStrategy

DomainEvent <|.. ScrimCreadoEvent
DomainEvent <|.. ScrimStateChangedEvent
DomainEventBus o-- Subscriber
Subscriber <|.. NotificationSubscriber
NotificationSubscriber --> NotificadorStrategy
NotificationSubscriber ..> Notificacion

NotificadorStrategy <|.. EmailNotificador
NotificadorStrategy <|.. PushNotificador
NotificadorStrategy <|.. DiscordNotificador
NotificadorStrategy <|.. SendGridEmailAdapter
NotificadorStrategy <|.. FirebasePushAdapter
NotificadorStrategy <|.. DiscordWebhookAdapter
NotificadorFactory <|.. DevNotificadorFactory
NotificadorFactory <|.. ProdNotificadorFactory
NotificadorFactory ..> NotificadorStrategy
ProdNotificadorFactory ..> SendGridEmailAdapter
ProdNotificadorFactory ..> FirebasePushAdapter
ProdNotificadorFactory ..> DiscordWebhookAdapter

@enduml
