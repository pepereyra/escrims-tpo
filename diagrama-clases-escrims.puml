@startuml
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam classHeaderBackgroundColor #DDEEFF
skinparam packageBackgroundColor #F8F8FF
hide empty members

title eScrims - Diagrama de clases

class ApiApplication <<SpringBootApplication>>

package facade {
    class ScrimFacade <<Facade>> {
        - controller: ScrimController
        + crearScrim(): ScrimContext
        + postular(): void
        + confirmar(): void
        + iniciar(): void
        + finalizar(): void
        + cancelar(): void
        + cambiarRol(): void
        + intercambiarRoles(): void
        + moverASuplente(): void
        + deshacerUltimoComando(): void
        + generarIcal(): String
        + procesarRecordatorios(): List
        + configurarNotificacionesEmail(): void
        + configurarNotificacionesPush(): void
        + configurarNotificacionesDiscord(): void
        + procesarScrimsProgramados(): int
        + registrarEstadisticas(): List
        + getScrim(): ScrimContext
    }
}

package controller {
    class ScrimController <<Controller>> {
        - scrimService: ScrimService
        + crearScrim(): ScrimContext
        + postular(): void
        + confirmar(): void
        + iniciar(): void
        + finalizar(): void
        + cancelar(): void
        + cambiarRol(): void
        + intercambiarRoles(): void
        + moverASuplente(): void
        + deshacerUltimoComando(): void
        + generarIcal(): String
        + procesarRecordatorios(): List
        + procesarScrimsProgramados(): int
        + registrarEstadisticas(): List
        + getScrim(): ScrimContext
    }
}

package controller_api {
    class ApiConfig <<Configuration>>
    class OpenApiConfig <<Configuration>>
    class AuthRestController <<RestController>>
    class UsuarioRestController <<RestController>>
    class ScrimRestController <<RestController>>
    class BusquedaFavoritaRestController <<RestController>>
    class CatalogoRestController <<RestController>>
    class FrontendRestController <<RestController>>
    class ModeracionRestController <<RestController>>
    class UsuarioApiRepository <<Repository>>
    class AuditRestController <<RestController>>
    class ApiDtos <<DTO>>
    class ApiExceptionHandler <<RestControllerAdvice>>
}

package service {
    interface ScrimRepository <<Repository>> {
        + save(scrim: ScrimContext): ScrimContext
        + findById(scrimId: UUID): Optional
        + findAll(): Collection
    }

    interface BusquedaFavoritaRepository <<Repository>>
    interface AlertaBusquedaRepository <<Repository>>
    interface AuditLogRepository <<Repository>>
    interface FeedbackRepository <<Repository>>
    interface ReporteConductaRepository <<Repository>>

    class InMemoryScrimRepository <<Repository>>
    class BusquedaFavoritaService <<Observer>>
    class AuditService <<Observer>>
    class AuthService <<Service>>
    class ModeracionService <<Service>>
    class ScrimReminderService <<Service>>
    class ScrimReminderScheduler <<Scheduled>>

    class ScrimService <<Service>> {
        - scrimRepository: ScrimRepository
        - eventBus: DomainEventBus
        - notificadorFactory: NotificadorFactory
        - schedulerService: ScrimSchedulerService
        - reminderService: ScrimReminderService
        + crearScrim(): ScrimContext
        + postular(): void
        + confirmar(): void
        + iniciar(): void
        + finalizar(): void
        + cancelar(): void
        + cambiarRol(): void
        + intercambiarRoles(): void
        + moverASuplente(): void
        + deshacerUltimoComando(): void
        + generarIcal(): String
        + procesarRecordatorios(): List
        + registrarEstadisticas(): List
        + getScrim(): ScrimContext
    }

    class ScrimSchedulerService <<Service>>
}

package infra_persistence {
    class UsuarioJpaEntity <<JPAEntity>>
    class ScrimJpaEntity <<JPAEntity>>
    class PostulacionJpaEntity <<JPAEntity>>
    class ConfirmacionJpaEntity <<JPAEntity>>
    class EstadisticaJpaEntity <<JPAEntity>>
    class FeedbackJpaEntity <<JPAEntity>>
    class ReporteConductaJpaEntity <<JPAEntity>>
    interface SpringDataUsuarioJpaRepository <<Repository>>
    interface SpringDataScrimJpaRepository <<Repository>>
    interface SpringDataFeedbackJpaRepository <<Repository>>
    interface SpringDataReporteConductaJpaRepository <<Repository>>
    interface SpringDataBusquedaFavoritaJpaRepository <<Repository>>
    interface SpringDataAlertaBusquedaJpaRepository <<Repository>>
    interface SpringDataAuditLogJpaRepository <<Repository>>
    class JpaScrimRepositoryAdapter <<RepositoryAdapter>>
    class JpaFeedbackRepositoryAdapter <<RepositoryAdapter>>
    class JpaReporteConductaRepositoryAdapter <<RepositoryAdapter>>
    class JpaBusquedaFavoritaRepositoryAdapter <<RepositoryAdapter>>
    class JpaAlertaBusquedaRepositoryAdapter <<RepositoryAdapter>>
    class JpaAuditLogRepositoryAdapter <<RepositoryAdapter>>
    class BusquedaFavoritaJpaEntity <<JPAEntity>>
    class AlertaBusquedaJpaEntity <<JPAEntity>>
    class AuditLogJpaEntity <<JPAEntity>>
}

package domain_model {
    class Usuario {
        - id: UUID
        - username: String
        - email: String
        - region: String
        - latenciaPromedio: int
        - verificado: boolean
        + verificarEmail(): void
        + isCooldownActivo(): boolean
        + getRangoEnJuego(): int
    }

    class Rol <<ValueObject>>
    class Equipo {
        - lado: String
        - jugadores: List
        + agregarJugador(): void
        + removerJugador(): void
        + estaCompleto(): boolean
    }
    class Confirmacion
    class Estadistica
    class Feedback
    class ReporteConducta {
        - etapaResolucion: String
    }
    class BusquedaFavorita
    class AlertaBusqueda
    class AuditLog
    class RecordatorioScrim

    class Postulacion {
        - usuario: Usuario
        - rolDeseado: Rol
        - estado: EstadoPostulacion
        + aceptar(): void
        + rechazar(): void
        + marcarSuplente(): void
        + cambiarRol(): void
        + estaAceptada(): boolean
    }

    interface EstadoPostulacion <<interface>>
    class PendientePostulacion
    class AceptadaPostulacion
    class RechazadaPostulacion
    class SuplentePostulacion

    class Notificacion
    interface EstadoNotificacion <<interface>>
    class PendienteNotificacion
    class EnviadaNotificacion
    class FallidaNotificacion
    interface EstadoModeracion <<interface>>
    class PendienteModeracion
    class AprobadoModeracion
    class RechazadoModeracion
}

package domain_state {
    interface ScrimState <<State>> {
        + postular(): void
        + confirmar(): void
        + iniciar(): void
        + finalizar(): void
        + cancelar(): void
        + getNombre(): String
    }

    class ScrimContext <<Context>> {
        - state: ScrimState
        - equipos: List
        - postulaciones: List
        - confirmaciones: List
        - estadisticas: List
        - modalidad: String
        - eventBus: DomainEventBus
        - matchmakingStrategy: MatchmakingStrategy
        + postular(): void
        + confirmar(): void
        + iniciar(): void
        + finalizar(): void
        + cancelar(): void
        + cambiarRol(): void
        + intercambiarRoles(): void
        + moverASuplente(): void
        + recomponerEquipos(): void
        + cuposDisponibles(): int
        + todosConfirmaron(): boolean
        + publicarEvento(): void
    }

    class ScrimBuilder <<Builder>>
    class BuscandoState
    class LobbyArmadoState
    class ConfirmadoState
    class EnJuegoState
    class FinalizadoState
    class CanceladoState
}

package domain_command {
    interface ScrimCommand <<Command>> {
        + ejecutar(): void
        + deshacer(): void
        + getScrim(): ScrimContext
    }

    class CambiarRolCommand <<ConcreteCommand>>
    class IntercambiarRolesCommand <<ConcreteCommand>>
    class MoverASuplenteCommand <<ConcreteCommand>>
}

package domain_moderation {
    interface ReporteModeracionHandler <<Handler>> {
        + resolver(): ReporteResolution
    }

    class AbstractReporteModeracionHandler <<ChainBase>> {
        + linkWith(): AbstractReporteModeracionHandler
    }
    class AutoResolveReporteHandler <<ConcreteHandler>>
    class BotModerationReporteHandler <<ConcreteHandler>>
    class HumanModerationReporteHandler <<ConcreteHandler>>
    class ReporteResolution
}

package domain_matchmaking {
    interface MatchmakingStrategy <<Strategy>>
    class ByMMRStrategy <<ConcreteStrategy>>
    class ByLatencyStrategy <<ConcreteStrategy>>
    class ByHistoryStrategy <<ConcreteStrategy>>
    class CompositeMatchmakingStrategy <<CompositeStrategy>>
}

package domain_rules {
    abstract class GameRulesTemplate <<TemplateMethod>> {
        + validarCreacion(): void
        + validarPostulacion(): void
        # validarModalidad(): void
        # validarCreacionEspecifica(): void
        # validarPostulacionEspecifica(): void
    }

    class ValorantGameRulesTemplate <<ConcreteTemplate>>
    class LeagueOfLegendsGameRulesTemplate <<ConcreteTemplate>>
    class Cs2GameRulesTemplate <<ConcreteTemplate>>
    class GenericGameRulesTemplate <<ConcreteTemplate>>
    class GameRulesValidator <<Utility>>
    class GameRulesRegistry <<Registry>>
}

package infra_events {
    interface DomainEvent <<Event>>
    class ScrimCreadoEvent
    class ScrimStateChangedEvent
    interface Subscriber <<Observer>>
    class DomainEventBus <<Subject>>
    class NotificationSubscriber <<Observer>>
}

package infra_notification {
    interface NotificadorStrategy <<Strategy>>
    class EmailNotificador <<ConcreteStrategy>>
    class PushNotificador <<ConcreteStrategy>>
    class DiscordNotificador <<ConcreteStrategy>>
    class SendGridEmailAdapter <<Adapter>>
    class FirebasePushAdapter <<Adapter>>
    class DiscordWebhookAdapter <<Adapter>>
    interface NotificationDispatcher <<QueuePort>>
    class QueuedNotificationDispatcher <<QueueRetry>>
    class RabbitNotificationDispatcher <<ExternalQueue>>
    class NotificationQueueMessage <<DTO>>
    class NotificationQueueNames <<Constants>>
    interface NotificationMessagePublisher <<PublisherPort>>
    class RabbitNotificationMessagePublisher <<Adapter>>
    class RabbitNotificationConsumer <<Consumer>>
    class RabbitNotificationConfig <<Configuration>>
    interface NotificadorFactory <<AbstractFactory>>
    class DevNotificadorFactory <<ConcreteFactory>>
    class ProdNotificadorFactory <<ConcreteFactory>>
}

package infra_calendar {
    interface CalendarAdapter <<Adapter>> {
        + generarEvento(scrim: ScrimContext): String
    }

    class ICalCalendarAdapter <<ConcreteAdapter>>
}

