title eScrims - Diagrama de datos API REST

package "Controladores REST" {
    class AuthRestController <<RestController>> {
        - authService: AuthService
        + AuthRestController(authService: AuthService)
        + register(request: ApiDtos.RegisterRequest): ApiDtos.AuthResponse
        + login(request: ApiDtos.LoginRequest): ApiDtos.AuthResponse
        + me(authorization: String): ApiDtos.UsuarioResponse
        + verificarEmail(authorization: String): ApiDtos.UsuarioResponse
        + actualizarPerfil(authorization: String, request: ApiDtos.ActualizarPerfilRequest): ApiDtos.UsuarioResponse
        - toResponse(usuario: Usuario): ApiDtos.UsuarioResponse
        }

    class UsuarioRestController <<RestController>> {
        - usuarios: UsuarioApiRepository
        + UsuarioRestController(usuarios: UsuarioApiRepository)
        + crear(request: ApiDtos.CrearUsuarioRequest): ApiDtos.UsuarioResponse
        + listar(): List<ApiDtos.UsuarioResponse>
        - toResponse(usuario: Usuario): ApiDtos.UsuarioResponse
        }

    class ScrimRestController <<RestController>> {
        - facade: ScrimFacade
        - usuarios: UsuarioApiRepository
        + ScrimRestController(facade: ScrimFacade, usuarios: UsuarioApiRepository)
        + crearScrim(request: ApiDtos.CrearScrimRequest): ApiDtos.ScrimResponse
        + obtenerScrim(scrimId: UUID): ApiDtos.ScrimResponse
        + buscarScrims(juego: String, formato: String, region: String, rangoMin: Integer, rangoMax: Integer, fecha: LocalDateTime, latenciaMax: Integer): List<ApiDtos.ScrimResponse>
        + postular(scrimId: UUID, request: ApiDtos.PostulacionRequest): ApiDtos.ScrimResponse
        + confirmar(scrimId: UUID, request: ApiDtos.UsuarioOperacionRequest): ApiDtos.ScrimResponse
        + iniciar(scrimId: UUID): ApiDtos.ScrimResponse
        + procesarScheduler(request: ApiDtos.SchedulerRequest): ApiDtos.SchedulerResponse
        + generarIcal(scrimId: UUID): ApiDtos.IcalResponse
        + procesarRecordatorios(request: ApiDtos.RecordatoriosRequest): List<ApiDtos.RecordatorioResponse>
        + finalizar(scrimId: UUID): ApiDtos.ScrimResponse
        + cancelar(scrimId: UUID): ApiDtos.ScrimResponse
        + cambiarRol(scrimId: UUID, request: ApiDtos.CambiarRolRequest): ApiDtos.ScrimResponse
        + intercambiarRoles(scrimId: UUID, request: ApiDtos.IntercambiarRolesRequest): ApiDtos.ScrimResponse
        + moverASuplente(scrimId: UUID, request: ApiDtos.UsuarioOperacionRequest): ApiDtos.ScrimResponse
        + reactivarTitular(scrimId: UUID, request: ApiDtos.UsuarioOperacionRequest): ApiDtos.ScrimResponse
        + deshacerUltimoComando(scrimId: UUID): ApiDtos.ScrimResponse
        + registrarEstadisticas(scrimId: UUID, request: ApiDtos.RegistrarEstadisticasRequest): List<ApiDtos.EstadisticaResponse>
        + configurarEmail(request: ApiDtos.NotificacionesRequest): void
        + configurarPush(request: ApiDtos.NotificacionesRequest): void
        + configurarDiscord(request: ApiDtos.NotificacionesRequest): void
        - buscarUsuarios(request: ApiDtos.NotificacionesRequest): List<Usuario>
        - coincide(filtro: String, valor: String): boolean
        - toResponse(scrim: ScrimContext): ApiDtos.ScrimResponse
        - toEquipoResponse(scrim: ScrimContext, equipo: Equipo): ApiDtos.EquipoResponse
        - toParticipanteResponse(scrim: ScrimContext, usuario: Usuario): ApiDtos.ParticipanteScrimResponse
        - toResponse(estadistica: Estadistica): ApiDtos.EstadisticaResponse
        - toResponse(recordatorio: RecordatorioScrim): ApiDtos.RecordatorioResponse
        }

    class FrontendRestController <<RestController>> {
        - facade: ScrimFacade
        - authService: AuthService
        - busquedaFavoritaService: BusquedaFavoritaService
        + FrontendRestController(facade: ScrimFacade, authService: AuthService, busquedaFavoritaService: BusquedaFavoritaService)
        + dashboard(authorization: String): ApiDtos.DashboardMeResponse
        + misScrims(authorization: String): ApiDtos.MisScrimsResponse
        + participantes(authorization: String, scrimId: UUID): ApiDtos.ParticipantesScrimResponse
        - misScrimsDe(usuario: Usuario): List<ApiDtos.MiScrimResponse>
        - toMiScrimResponse(scrim: ScrimContext, usuario: Usuario): ApiDtos.MiScrimResponse
        - participantesPorEstado(scrim: ScrimContext, estado: String): List<ApiDtos.ParticipanteScrimResponse>
        - toParticipanteResponse(scrim: ScrimContext, postulacion: Postulacion): ApiDtos.ParticipanteScrimResponse
        - toEquipoResponse(scrim: ScrimContext, equipo: Equipo): ApiDtos.EquipoResponse
        - postulacionDe(scrim: ScrimContext, usuario: Usuario): Postulacion
        - confirmacionDe(scrim: ScrimContext, usuario: Usuario): Confirmacion
        - toUsuarioResponse(usuario: Usuario): ApiDtos.UsuarioResponse
        - toAlertaResponse(alerta: AlertaBusqueda): ApiDtos.AlertaBusquedaResponse
        }

    class BusquedaFavoritaRestController <<RestController>> {
        - service: BusquedaFavoritaService
        - authService: AuthService
        + BusquedaFavoritaRestController(service: BusquedaFavoritaService, authService: AuthService)
        + guardar(authorization: String, request: ApiDtos.BusquedaFavoritaRequest): ApiDtos.BusquedaFavoritaResponse
        + listarBusquedas(authorization: String): List<ApiDtos.BusquedaFavoritaResponse>
        + listarAlertas(authorization: String): List<ApiDtos.AlertaBusquedaResponse>
        - toResponse(busqueda: BusquedaFavorita): ApiDtos.BusquedaFavoritaResponse
        - toResponse(alerta: AlertaBusqueda): ApiDtos.AlertaBusquedaResponse
        }

    class ModeracionRestController <<RestController>> {
        - moderacionService: ModeracionService
        - usuarios: UsuarioApiRepository
        - authService: AuthService
        - auditService: AuditService
        + ModeracionRestController(moderacionService: ModeracionService, usuarios: UsuarioApiRepository, authService: AuthService, auditService: AuditService)
        + registrarFeedback(scrimId: UUID, request: ApiDtos.FeedbackRequest): ApiDtos.FeedbackResponse
        + listarFeedback(scrimId: UUID): List<ApiDtos.FeedbackResponse>
        + aprobarFeedback(feedbackId: UUID, authorization: String): ApiDtos.FeedbackResponse
        + rechazarFeedback(feedbackId: UUID, authorization: String): ApiDtos.FeedbackResponse
        + registrarReporte(scrimId: UUID, request: ApiDtos.ReporteConductaRequest): ApiDtos.ReporteConductaResponse
        + listarReportes(scrimId: UUID): List<ApiDtos.ReporteConductaResponse>
        + aprobarReporte(reporteId: UUID, authorization: String, request: ApiDtos.ResolverReporteRequest): ApiDtos.ReporteConductaResponse
        + rechazarReporte(reporteId: UUID, authorization: String): ApiDtos.ReporteConductaResponse
        - toResponse(feedback: Feedback): ApiDtos.FeedbackResponse
        - toResponse(reporte: ReporteConducta): ApiDtos.ReporteConductaResponse
        }

    class CatalogoRestController <<RestController>> {
        - gameRulesRegistry: GameRulesRegistry
        + catalogos(): ApiDtos.CatalogosResponse
        }

    class AuditRestController <<RestController>> {
        - auditService: AuditService
        - authService: AuthService
        + AuditRestController(auditService: AuditService, authService: AuthService)
        + listar(authorization: String): List<ApiDtos.AuditLogResponse>
        - toResponse(log: AuditLog): ApiDtos.AuditLogResponse
        }

    class ApiExceptionHandler <<RestControllerAdvice>> {
        + handleIllegalArgument(e: IllegalArgumentException): ApiDtos.ErrorResponse
        + handleUnauthorized(e: UnauthorizedException): ApiDtos.ErrorResponse
        + handleForbidden(e: ForbiddenException): ApiDtos.ErrorResponse
        + handleTooManyRequests(e: TooManyRequestsException): ApiDtos.ErrorResponse
        + handleIllegalState(e: IllegalStateException): ApiDtos.ErrorResponse
        }

}

