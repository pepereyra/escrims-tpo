@startuml diagrama-clases-entrega

skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam classHeaderBackgroundColor #DDEEFF
skinparam packageBackgroundColor #F8F8FF
skinparam packageBorderColor #999999
skinparam shadowing false
left to right direction

title eScrims - Diagrama de clases para entrega

package "Aplicacion" {
    class ScrimFacade <<Facade>> {
        - controller: ScrimController
        --
        + crearScrim(...): ScrimContext
        + postular(scrimId: UUID, usuario: Usuario, rol: Rol): void
        + confirmar(scrimId: UUID, usuario: Usuario): void
        + iniciar(scrimId: UUID): void
        + finalizar(scrimId: UUID): void
        + cancelar(scrimId: UUID): void
        + cambiarRol(scrimId: UUID, usuario: Usuario, nuevoRol: Rol): void
        + intercambiarRoles(scrimId: UUID, usuarioA: Usuario, usuarioB: Usuario): void
        + moverASuplente(scrimId: UUID, usuario: Usuario): void
        + reactivarTitular(scrimId: UUID, usuario: Usuario): void
        + deshacerUltimoComando(scrimId: UUID): void
        + generarIcal(scrimId: UUID): String
        + procesarRecordatorios(ahora: LocalDateTime, horasAntes: int): List<RecordatorioScrim>
        + registrarEstadisticas(scrimId: UUID, resultados: Map<Usuario, int[]>): List<Estadistica>
        + listarScrims(): List<ScrimContext>
    }

    class ScrimController <<Controller>> {
        - scrimService: ScrimService
        --
        + crearScrim(...): ScrimContext
        + postular(scrimId: UUID, usuario: Usuario, rol: Rol): void
        + confirmar(scrimId: UUID, usuario: Usuario): void
        + iniciar(scrimId: UUID): void
        + finalizar(scrimId: UUID): void
        + cancelar(scrimId: UUID): void
        + cambiarRol(scrimId: UUID, usuario: Usuario, nuevoRol: Rol): void
        + deshacerUltimoComando(scrimId: UUID): void
        + generarIcal(scrimId: UUID): String
    }

    class ScrimService <<Service>> {
        - scrimRepository: ScrimRepository
        - eventBus: DomainEventBus
        - notificadorFactory: NotificadorFactory
        - schedulerService: ScrimSchedulerService
        - reminderService: ScrimReminderService
        - notificationDispatcher: NotificationDispatcher
        - commandHistory: Map<UUID, Deque<ScrimCommand>>
        --
        + crearScrim(...): ScrimContext
        + postular(scrimId: UUID, usuario: Usuario, rol: Rol): void
        + confirmar(scrimId: UUID, usuario: Usuario): void
        + iniciar(scrimId: UUID): void
        + finalizar(scrimId: UUID): void
        + cancelar(scrimId: UUID): void
        + cambiarRol(scrimId: UUID, usuario: Usuario, nuevoRol: Rol): void
        + intercambiarRoles(scrimId: UUID, usuarioA: Usuario, usuarioB: Usuario): void
        + moverASuplente(scrimId: UUID, usuario: Usuario): void
        + reactivarTitular(scrimId: UUID, usuario: Usuario): void
        + deshacerUltimoComando(scrimId: UUID): void
        + registrarEstadisticas(scrimId: UUID, resultados: Map<Usuario, int[]>): List<Estadistica>
        + procesarScrimsProgramados(ahora: LocalDateTime): int
        + procesarRecordatorios(ahora: LocalDateTime, horasAntes: int): List<RecordatorioScrim>
        + getScrim(scrimId: UUID): ScrimContext
        + listarScrims(): List<ScrimContext>
    }
}

package "Dominio principal" {
    class ScrimContext <<AggregateRoot, StateContext>> {
        - id: UUID
        - juego: String
        - formato: String
        - region: String
        - rangoMin: int
        - rangoMax: int
        - latenciaMax: int
        - fechaHora: LocalDateTime
        - duracionMinutos: int
        - cuposTotales: int
        - modalidad: String
        - state: ScrimState
        - equipos: List<Equipo>
        - postulaciones: List<Postulacion>
        - confirmaciones: List<Confirmacion>
        - estadisticas: List<Estadistica>
        - eventBus: DomainEventBus
        - matchmakingStrategy: MatchmakingStrategy
        --
        + postular(usuario: Usuario, rol: Rol): void
        + confirmar(usuario: Usuario): void
        + iniciar(): void
        + finalizar(): void
        + cancelar(): void
        + setState(nuevoEstado: ScrimState): void
        + restaurarEstado(estadoPersistido: ScrimState): void
        + recomponerEquipos(): void
        + publicarEvento(evento: DomainEvent): void
        + cuposDisponibles(): int
        + todosConfirmaron(): boolean
        + usuarioYaPostulado(usuario: Usuario): boolean
        + cambiarRol(usuario: Usuario, nuevoRol: Rol): void
        + intercambiarRoles(usuarioA: Usuario, usuarioB: Usuario): void
        + moverASuplente(usuario: Usuario): void
        + reactivarTitular(usuario: Usuario): void
    }

    class Usuario <<Entity>> {
        - id: UUID
        - username: String
        - email: String
        - passwordHash: String
        - rangoPorJuego: Map<String, Integer>
        - rolesPreferidos: List<Rol>
        - region: String
        - latenciaPromedio: int
        - disponibilidad: String
        - rolSistema: String
        - strikes: int
        - cooldownHasta: LocalDateTime
        - verificado: boolean
        --
        + verificarEmail(): void
        + agregarStrike(): void
        + activarCooldown(horas: int): void
        + isCooldownActivo(): boolean
        + getRangoEnJuego(juego: String): int
    }

    class Rol <<ValueObject>> {
        - nombre: String
        - juego: String
        --
        + getNombre(): String
        + getJuego(): String
    }

    class Equipo <<Entity>> {
        - id: UUID
        - lado: String
        - jugadores: List<Usuario>
        --
        + agregarJugador(usuario: Usuario): void
        + removerJugador(usuario: Usuario): void
        + estaCompleto(cuposPorLado: int): boolean
    }

    class Postulacion <<Entity>> {
        - id: UUID
        - usuario: Usuario
        - rolDeseado: Rol
        - estado: EstadoPostulacion
        - fechaPostulacion: LocalDateTime
        --
        + aceptar(): void
        + rechazar(): void
        + marcarSuplente(): void
        + cambiarRol(nuevoRol: Rol): void
        + restaurar(rol: Rol, estado: String): void
        + estaAceptada(): boolean
    }

    class Confirmacion <<Entity>> {
        - id: UUID
        - usuario: Usuario
        - confirmado: boolean
        - fechaConfirmacion: LocalDateTime
        --
        + confirmar(): void
    }

    class Estadistica <<Entity>> {
        - id: UUID
        - usuario: Usuario
        - mvp: boolean
        - kills: int
        - deaths: int
        - assists: int
        - observaciones: String
        --
        + getKda(): double
        + setMvp(mvp: boolean): void
    }
}

package "State - ciclo de vida" {
    interface ScrimState <<State>> {
        + postular(ctx: ScrimContext, usuario: Usuario, rol: Rol): void
        + confirmar(ctx: ScrimContext, usuario: Usuario): void
        + iniciar(ctx: ScrimContext): void
        + finalizar(ctx: ScrimContext): void
        + cancelar(ctx: ScrimContext): void
        + getNombre(): String
    }

    class BuscandoState <<ConcreteState>>
    class LobbyArmadoState <<ConcreteState>>
    class ConfirmadoState <<ConcreteState>>
    class EnJuegoState <<ConcreteState>>
    class FinalizadoState <<ConcreteState>>
    class CanceladoState <<ConcreteState>>
}

package "Strategy - matchmaking" {
    interface MatchmakingStrategy <<Strategy>> {
        + esCompatible(usuario: Usuario, scrim: ScrimContext): boolean
    }

    class ByMMRStrategy <<ConcreteStrategy>> {
        + esCompatible(usuario: Usuario, scrim: ScrimContext): boolean
    }

    class ByLatencyStrategy <<ConcreteStrategy>> {
        + esCompatible(usuario: Usuario, scrim: ScrimContext): boolean
    }

    class ByHistoryStrategy <<ConcreteStrategy>> {
        + esCompatible(usuario: Usuario, scrim: ScrimContext): boolean
    }

    class CompositeMatchmakingStrategy <<CompositeStrategy>> {
        - strategies: List<MatchmakingStrategy>
        --
        + esCompatible(usuario: Usuario, scrim: ScrimContext): boolean
    }
}

package "Builder + Template Method - reglas por juego" {
    class ScrimBuilder <<Builder>> {
        - juego: String
        - formato: String
        - region: String
        - rangoMin: int
        - rangoMax: int
        - latenciaMax: int
        - fechaHora: LocalDateTime
        - duracionMinutos: int
        - cuposTotales: int
        - modalidad: String
        - matchmakingStrategy: MatchmakingStrategy
        - gameRulesRegistry: GameRulesRegistry
        - eventBus: DomainEventBus
        --
        + juego(juego: String): ScrimBuilder
        + formato(formato: String): ScrimBuilder
        + region(region: String): ScrimBuilder
        + rango(rangoMin: int, rangoMax: int): ScrimBuilder
        + latenciaMax(latenciaMax: int): ScrimBuilder
        + fechaHora(fechaHora: LocalDateTime): ScrimBuilder
        + duracionMinutos(duracionMinutos: int): ScrimBuilder
        + cuposTotales(cuposTotales: int): ScrimBuilder
        + modalidad(modalidad: String): ScrimBuilder
        + matchmakingStrategy(strategy: MatchmakingStrategy): ScrimBuilder
        + build(): ScrimContext
    }

    abstract class GameRulesTemplate <<TemplateMethod>> {
        + validarCreacion(formato: String, cuposTotales: int, modalidad: String): void
        + validarPostulacion(scrim: ScrimContext, rol: Rol): void
        + getJuego(): String
        + formatosPermitidos(): List<String>
        + rolesPermitidos(): List<String>
        # validarModalidad(modalidad: String): void
        # validarCreacionEspecifica(formato: String, cuposTotales: int, modalidad: String): void
        # validarPostulacionEspecifica(scrim: ScrimContext, rol: Rol): void
    }

    class GameRulesRegistry <<Registry>> {
        - reglasPorJuego: Map<String, GameRulesTemplate>
        - reglasSoportadas: List<GameRulesTemplate>
        - reglasGenericas: GameRulesTemplate
        --
        + obtenerPara(juego: String): GameRulesTemplate
        + listarSoportadas(): List<GameRulesTemplate>
    }

    class ValorantGameRulesTemplate <<ConcreteTemplate>>
    class LeagueOfLegendsGameRulesTemplate <<ConcreteTemplate>>
    class Cs2GameRulesTemplate <<ConcreteTemplate>>
    class GenericGameRulesTemplate <<ConcreteTemplate>>
}

package "Command - gestion de lobby" {
    interface ScrimCommand <<Command>> {
        + ejecutar(): void
        + deshacer(): void
        + getScrim(): ScrimContext
    }

    class CambiarRolCommand <<ConcreteCommand>> {
        - scrim: ScrimContext
        - usuario: Usuario
        - nuevoRol: Rol
        - rolAnterior: Rol
        - ejecutado: boolean
        --
        + ejecutar(): void
        + deshacer(): void
        + getScrim(): ScrimContext
    }

    class IntercambiarRolesCommand <<ConcreteCommand>> {
        - scrim: ScrimContext
        - usuarioA: Usuario
        - usuarioB: Usuario
        - rolAnteriorA: Rol
        - rolAnteriorB: Rol
        - ejecutado: boolean
        --
        + ejecutar(): void
        + deshacer(): void
        + getScrim(): ScrimContext
    }

    class MoverASuplenteCommand <<ConcreteCommand>> {
        - scrim: ScrimContext
        - usuario: Usuario
        - rolAnterior: Rol
        - estadoPostulacionAnterior: String
        - estadoScrimAnterior: ScrimState
        - ejecutado: boolean
        --
        + ejecutar(): void
        + deshacer(): void
        + getScrim(): ScrimContext
    }

    class ReactivarTitularCommand <<ConcreteCommand>> {
        - scrim: ScrimContext
        - usuario: Usuario
        - rolAnterior: Rol
        - estadoPostulacionAnterior: String
        - estadoScrimAnterior: ScrimState
        - ejecutado: boolean
        --
        + ejecutar(): void
        + deshacer(): void
        + getScrim(): ScrimContext
    }
}

package "Observer + notificaciones" {
    interface DomainEvent <<Event>> {
        + getScrimId(): UUID
        + getTipo(): String
        + getFecha(): LocalDateTime
    }

    class ScrimCreadoEvent <<DomainEvent>> {
        - scrimId: UUID
        - juego: String
        - region: String
        - formato: String
        - cuposTotales: int
        - fecha: LocalDateTime
        --
        + getTipo(): String
    }

    class ScrimStateChangedEvent <<DomainEvent>> {
        - scrimId: UUID
        - estadoAnterior: String
        - nuevoEstado: String
        - fecha: LocalDateTime
        --
        + getTipo(): String
    }

    interface Subscriber <<Observer>> {
        + onEvent(evento: DomainEvent): void
    }

    class DomainEventBus <<Subject>> {
        - subscribers: List<Subscriber>
        --
        + subscribe(subscriber: Subscriber): void
        + unsubscribe(subscriber: Subscriber): void
        + publish(evento: DomainEvent): void
        + cantidadSuscriptores(): int
    }

    class NotificationSubscriber <<Observer>> {
        - destinatarios: List<Usuario>
        - notificador: NotificadorStrategy
        - dispatcher: NotificationDispatcher
        --
        + onEvent(evento: DomainEvent): void
        + agregarDestinatario(usuario: Usuario): void
        + removerDestinatario(usuario: Usuario): void
    }

    interface NotificadorFactory <<AbstractFactory>> {
        + crearEmailNotificador(): NotificadorStrategy
        + crearPushNotificador(): NotificadorStrategy
        + crearDiscordNotificador(): NotificadorStrategy
    }

    class DevNotificadorFactory <<ConcreteFactory>>
    class ProdNotificadorFactory <<ConcreteFactory>>

    interface NotificadorStrategy <<Strategy>> {
        + getCanal(): String
        + enviar(destinatario: Usuario, notificacion: Notificacion): void
    }

    class EmailNotificador <<Notifier>>
    class PushNotificador <<Notifier>>
    class DiscordNotificador <<Notifier>>
    class SendGridEmailAdapter <<Adapter>>
    class FirebasePushAdapter <<Adapter>>
    class DiscordWebhookAdapter <<Adapter>>
}

package "Infraestructura" {
    interface NotificationDispatcher <<QueuePort>> {
        + enqueue(destinatario: Usuario, notificacion: Notificacion, notificador: NotificadorStrategy): void
        + pendientes(): int
    }

    class QueuedNotificationDispatcher <<RetryQueue>> {
        - queue: Queue<NotificationJob>
        --
        + enqueue(destinatario: Usuario, notificacion: Notificacion, notificador: NotificadorStrategy): void
        + pendientes(): int
    }

    class RabbitNotificationDispatcher <<ExternalQueue>> {
        - publisher: NotificationMessagePublisher
        --
        + enqueue(destinatario: Usuario, notificacion: Notificacion, notificador: NotificadorStrategy): void
        + pendientes(): int
    }

    interface CalendarAdapter <<Adapter>> {
        + generarEvento(scrim: ScrimContext): String
    }

    class ICalCalendarAdapter <<Adapter>> {
        + generarEvento(scrim: ScrimContext): String
    }

    interface ScrimRepository <<Repository>> {
        + save(scrim: ScrimContext): ScrimContext
        + findById(id: UUID): Optional<ScrimContext>
        + findAll(): List<ScrimContext>
        + deleteAll(): void
    }

    class JpaScrimRepositoryAdapter <<RepositoryAdapter>>
    class InMemoryScrimRepository <<Repository>>
}

package "Moderacion" {
    class Feedback <<Entity>> {
        - id: UUID
        - scrimId: UUID
        - autor: Usuario
        - destinatario: Usuario
        - rating: int
        - comentario: String
        - estado: EstadoModeracion
        --
        + aprobar(): void
        + rechazar(): void
    }

    class ReporteConducta <<Entity>> {
        - id: UUID
        - scrimId: UUID
        - reportante: Usuario
        - reportado: Usuario
        - motivo: String
        - estado: EstadoModeracion
        - sancion: String
        - etapaResolucion: String
        --
        + aprobar(sancion: String): void
        + rechazar(): void
        + marcarEtapaResolucion(etapa: String): void
    }

    interface ReporteModeracionHandler <<Handler>> {
        + resolver(reporte: ReporteConducta): ReporteResolution
    }

    abstract class AbstractReporteModeracionHandler <<ChainBase>> {
        - siguiente: ReporteModeracionHandler
        --
        + linkWith(siguiente: ReporteModeracionHandler): AbstractReporteModeracionHandler
        + resolver(reporte: ReporteConducta): ReporteResolution
    }

    class AutoResolveReporteHandler <<ConcreteHandler>>
    class BotModerationReporteHandler <<ConcreteHandler>>
    class HumanModerationReporteHandler <<ConcreteHandler>>
}

' Relaciones principales
ScrimFacade --> ScrimController
ScrimController --> ScrimService
ScrimService --> ScrimRepository
ScrimService --> DomainEventBus
ScrimService --> NotificadorFactory
ScrimService --> NotificationDispatcher
ScrimService ..> ScrimBuilder
ScrimService ..> ScrimCommand

ScrimContext --> ScrimState
ScrimContext --> MatchmakingStrategy
ScrimContext --> DomainEventBus
ScrimContext *-- Equipo
ScrimContext *-- Postulacion
ScrimContext *-- Confirmacion
ScrimContext *-- Estadistica

Equipo o-- Usuario
Postulacion --> Usuario
Postulacion --> Rol
Confirmacion --> Usuario
Estadistica --> Usuario
Usuario o-- Rol

ScrimState <|.. BuscandoState
ScrimState <|.. LobbyArmadoState
ScrimState <|.. ConfirmadoState
ScrimState <|.. EnJuegoState
ScrimState <|.. FinalizadoState
ScrimState <|.. CanceladoState

MatchmakingStrategy <|.. ByMMRStrategy
MatchmakingStrategy <|.. ByLatencyStrategy
MatchmakingStrategy <|.. ByHistoryStrategy
MatchmakingStrategy <|.. CompositeMatchmakingStrategy
CompositeMatchmakingStrategy o-- MatchmakingStrategy

ScrimBuilder ..> ScrimContext
ScrimBuilder --> MatchmakingStrategy
ScrimBuilder --> GameRulesRegistry
GameRulesRegistry o-- GameRulesTemplate
GameRulesTemplate <|-- ValorantGameRulesTemplate
GameRulesTemplate <|-- LeagueOfLegendsGameRulesTemplate
GameRulesTemplate <|-- Cs2GameRulesTemplate
GameRulesTemplate <|-- GenericGameRulesTemplate

ScrimCommand <|.. CambiarRolCommand
ScrimCommand <|.. IntercambiarRolesCommand
ScrimCommand <|.. MoverASuplenteCommand
ScrimCommand <|.. ReactivarTitularCommand
CambiarRolCommand --> ScrimContext
IntercambiarRolesCommand --> ScrimContext
MoverASuplenteCommand --> ScrimContext
ReactivarTitularCommand --> ScrimContext

DomainEvent <|.. ScrimCreadoEvent
DomainEvent <|.. ScrimStateChangedEvent
DomainEventBus o-- Subscriber
Subscriber <|.. NotificationSubscriber
NotificationSubscriber --> NotificadorStrategy
NotificationSubscriber --> NotificationDispatcher
NotificadorFactory ..> NotificadorStrategy
NotificadorFactory <|.. DevNotificadorFactory
NotificadorFactory <|.. ProdNotificadorFactory
NotificadorStrategy <|.. EmailNotificador
NotificadorStrategy <|.. PushNotificador
NotificadorStrategy <|.. DiscordNotificador
NotificadorStrategy <|.. SendGridEmailAdapter
NotificadorStrategy <|.. FirebasePushAdapter
NotificadorStrategy <|.. DiscordWebhookAdapter

NotificationDispatcher <|.. QueuedNotificationDispatcher
NotificationDispatcher <|.. RabbitNotificationDispatcher
CalendarAdapter <|.. ICalCalendarAdapter
ScrimRepository <|.. JpaScrimRepositoryAdapter
ScrimRepository <|.. InMemoryScrimRepository

Feedback --> Usuario : autor/destinatario
ReporteConducta --> Usuario : reportante/reportado
ReporteModeracionHandler <|.. AbstractReporteModeracionHandler
AbstractReporteModeracionHandler <|-- AutoResolveReporteHandler
AbstractReporteModeracionHandler <|-- BotModerationReporteHandler
ReporteModeracionHandler <|.. HumanModerationReporteHandler

legend right
  Diagrama para entrega:
  - Excluye DTOs, seeders, excepciones y configuracion tecnica menor.
  - Mantiene clases relevantes del dominio, aplicacion, infraestructura y patrones.
  - Los estereotipos marcan trazabilidad directa con la consigna.
endlegend

@enduml
